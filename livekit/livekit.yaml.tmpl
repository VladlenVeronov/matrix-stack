# =============================================================
# LiveKit SFU config — rendered by livekit/entrypoint.sh.
# Used by Element Call (group voice/video) for VIR.GROUP.
# =============================================================

port: 7880
bind_addresses:
  - "0.0.0.0"

rtc:
  # UDP port range for media — kept BELOW Linux's ephemeral range
  # (32768–60999) to avoid conflicts with outbound connections.
  # 7882–7999 = 118 simultaneous WebRTC peers; raise if needed.
  port_range_start: 7882
  port_range_end: 7999
  # TCP fallback for restrictive NATs
  tcp_port: 7881
  # External IP must be the public host (server's WAN address)
  use_external_ip: true

keys:
  ${LIVEKIT_API_KEY}: ${LIVEKIT_API_SECRET}

logging:
  json: true
  level: info

room:
  enable_remote_unmute: true
  max_participants: 50
  empty_timeout: 300
