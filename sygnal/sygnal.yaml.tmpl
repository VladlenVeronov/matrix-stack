# =============================================================
# Sygnal — Matrix push gateway config
# Rendered from this template by sygnal/entrypoint.sh at boot.
#
# Synapse calls Sygnal at  http://sygnal:5000/_matrix/push/v1/notify
# Sygnal forwards to:
#   - FCM v1 → Android (and Web Push, when we add it)
#   - APNs   → iOS
#
# Privacy: only event_id + room_id + sender are forwarded. The Megolm-
# encrypted body never leaves the homeserver. The Flutter client wakes
# up on push, then pulls the event from Synapse and decrypts locally.
# =============================================================

log:
  setup:
    version: 1
    handlers:
      stderr:
        class: logging.StreamHandler
        stream: ext://sys.stderr
        formatter: normal
    formatters:
      normal:
        format: '%(asctime)s [%(process)d] %(levelname)-8s %(name)s %(message)s'
    loggers:
      sygnal.access:
        propagate: false
        handlers: [stderr]
        level: INFO
    root:
      level: INFO
      handlers: [stderr]
  access:
    x_forwarded_for: true

http:
  bind_addresses: ['0.0.0.0']
  port: 5000

apps:

  # -----------------------------------------------------------
  # Android (FCM v1)
  # -----------------------------------------------------------
  ${SYGNAL_APNS_BUNDLE_ID}.android:
    type: gcm
    api_version: v1
    project_id: "${SYGNAL_FCM_PROJECT_ID}"
    service_account_file: "${SYGNAL_FCM_SERVICE_ACCOUNT_PATH}"
    # E2EE-friendly: no body in payload — Sygnal forwards only event_id +
    # room_id + sender. Keep fcm_options EMPTY: it is the literal FCM v1
    # message body, so any custom field fails 400 INVALID_ARGUMENT (verified
    # 2026-05-07: content_available/mutable_content APNs-only, default_payload
    # not in v1 schema). Sygnal itself injects "priority": "high" already
    # (gcmpushkin.py L568); nothing to override here.
    fcm_options: {}

  # -----------------------------------------------------------
  # iOS (APNs)
  # -----------------------------------------------------------
  ${SYGNAL_APNS_BUNDLE_ID}.ios:
    type: apns
    keyfile: "${SYGNAL_APNS_KEY_PATH}"
    key_id: "${SYGNAL_APNS_KEY_ID}"
    team_id: "${SYGNAL_APNS_TEAM_ID}"
    topic: "${SYGNAL_APNS_BUNDLE_ID}"
    platform: production
    push_type: alert

  # -----------------------------------------------------------
  # iOS PushKit / VoIP (CallKit wake on m.call.invite while killed)
  # Same .p8 key — Apple Auth Keys are scoped per-team, NOT per-topic.
  # Topic MUST end in .voip; push_type=voip routes via PKPushRegistry.
  # -----------------------------------------------------------
  ${SYGNAL_APNS_BUNDLE_ID}.voip:
    type: apns
    keyfile: "${SYGNAL_APNS_KEY_PATH}"
    key_id: "${SYGNAL_APNS_KEY_ID}"
    team_id: "${SYGNAL_APNS_TEAM_ID}"
    topic: "${SYGNAL_APNS_BUNDLE_ID}.voip"
    platform: production
    push_type: voip
