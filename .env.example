# =============================================================
# matrix-stack — example environment
# Copy to .env, then run scripts/gen_secrets.sh to fill secrets.
# In production: paste these values into Coolify "Environment Variables".
# =============================================================

# -------------------------------------------------------------
# Public-facing
# -------------------------------------------------------------
# Homeserver name as it appears in user IDs: @user:vir.group
SYNAPSE_SERVER_NAME=vir.group

# Where the Matrix client connects (must match a domain set in Coolify)
SYNAPSE_PUBLIC_BASEURL=https://matrix.vir.group

# Bridge-API and Admin SPA public URLs
BRIDGE_PUBLIC_URL=https://bridge.vir.group
ADMIN_PUBLIC_URL=https://admin.matrix.vir.group

# -------------------------------------------------------------
# Synapse — feature flags
# -------------------------------------------------------------
SYNAPSE_REPORT_STATS=no
SYNAPSE_ENABLE_REGISTRATION=false      # public signup OFF — bridge-api provisions users
SYNAPSE_ALLOW_GUEST_ACCESS=false
SYNAPSE_PASSWORD_LOGIN_ENABLED=false   # auth only via bridge-issued tokens
SYNAPSE_FEDERATION_ENABLED=false       # closed ecosystem
SYNAPSE_ENCRYPTION_DEFAULT=true        # all new private/group rooms E2EE by default
SYNAPSE_LOG_LEVEL=INFO

# Max upload size (Mb); raise for large file/video sharing
SYNAPSE_MAX_UPLOAD_SIZE_MB=100

# -------------------------------------------------------------
# Synapse — secrets (run ./scripts/gen_secrets.sh to generate)
# -------------------------------------------------------------
SYNAPSE_REGISTRATION_SHARED_SECRET=__GENERATE_ME__
SYNAPSE_MACAROON_SECRET_KEY=__GENERATE_ME__
SYNAPSE_FORM_SECRET=__GENERATE_ME__

# -------------------------------------------------------------
# Postgres (Synapse-dedicated, NOT Supabase)
# -------------------------------------------------------------
MATRIX_PG_HOST=postgres-matrix
MATRIX_PG_PORT=5432
MATRIX_PG_USER=synapse
MATRIX_PG_PASSWORD=__GENERATE_ME__
MATRIX_PG_DB=synapse

# -------------------------------------------------------------
# Redis (Synapse cache / workers)
# -------------------------------------------------------------
MATRIX_REDIS_PASSWORD=__GENERATE_ME__

# -------------------------------------------------------------
# Bridge-API (Supabase ↔ Matrix link)
# -------------------------------------------------------------
BRIDGE_LOG_LEVEL=INFO

# Supabase project that the bridge trusts JWTs from
BRIDGE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
BRIDGE_SUPABASE_JWT_SECRET=__FROM_SUPABASE_DASHBOARD__
BRIDGE_SUPABASE_SERVICE_ROLE=__FROM_SUPABASE_DASHBOARD__

# Synapse Admin API token used by bridge to provision users
# Created once via scripts/init_admin_user.sh after first deploy
BRIDGE_SYNAPSE_ADMIN_TOKEN=__FILL_AFTER_FIRST_DEPLOY__

# Webhook signing secret — Supabase trigger sends this in X-Webhook-Signature.
# Leave empty to disable /users/sync entirely.
BRIDGE_WEBHOOK_SECRET=__GENERATE_ME__

# -------------------------------------------------------------
# Push (Sygnal) — fill when adding push module in Phase 2
# -------------------------------------------------------------
# FCM (Android + Web)
SYGNAL_FCM_PROJECT_ID=vir-group-777
# Path inside container — mount /secrets read-only
SYGNAL_FCM_SERVICE_ACCOUNT_PATH=/secrets/fcm-service-account.json

# APNs (iOS)
SYGNAL_APNS_TEAM_ID=MU99922923
SYGNAL_APNS_KEY_ID=35S4HAP4G7
SYGNAL_APNS_BUNDLE_ID=__CONFIRM_PROD_BUNDLE_ID__
SYGNAL_APNS_KEY_PATH=/secrets/apns-AuthKey_35S4HAP4G7.p8

# -------------------------------------------------------------
# LiveKit (group voice/video) — fill when adding RTC module
# -------------------------------------------------------------
LIVEKIT_API_KEY=__GENERATE_ME__
LIVEKIT_API_SECRET=__GENERATE_ME__
LIVEKIT_PUBLIC_URL=https://livekit.matrix.vir.group
